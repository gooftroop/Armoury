{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "../../src/tooling/typescript/base.json",
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "outDir": "./dist",
        "rootDir": ".",
        "noEmit": true,
        "types": ["node"],
        "noUnusedLocals": false,
        "noUnusedParameters": false
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
