{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "generate:theme": {
            "cache": false
        },
        "copy:systems": {
            "dependsOn": ["^build", "@armoury/theme-generator#generate:theme"],
            "outputs": ["public/systems/**"],
            "cache": false
        },
        "build": {
            "dependsOn": ["^build", "^generate:types", "copy:systems"],
            "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
            "env": [
                "SENTRY_DSN",
                "SENTRY_ORG",
                "SENTRY_PROJECT",
                "NEXT_PUBLIC_SENTRY_DSN",
                "NEXT_PUBLIC_REST_BASE_URL",
                "NEXT_PUBLIC_WS_BASE_URL",
                "NEXT_PUBLIC_WS_PATH_PREFIX",
                "NEXT_PUBLIC_USERS_BASE_URL",
                "NEXT_PUBLIC_FRIENDS_BASE_URL",
                "NEXT_PUBLIC_FRIENDS_WS_URL",
                "NEXT_PUBLIC_MATCHES_BASE_URL",
                "NEXT_PUBLIC_MATCHES_WS_URL",
                "NEXT_PUBLIC_CAMPAIGNS_BASE_URL"
            ],
            "passThroughEnv": ["SENTRY_AUTH_TOKEN"]
        },
        "generate:types": {
            "dependsOn": ["^generate:types"],
            "outputs": ["dist/**/*.d.ts", "dist/**/*.d.ts.map"]
        },
        "test": {
            "dependsOn": ["^generate:types", "copy:systems"],
            "outputs": []
        },
        "test:integration": {
            "dependsOn": ["^generate:types"],
            "outputs": [],
            "env": ["GITHUB_TOKEN"]
        },
        "lint": {
            "outputs": []
        },
        "typecheck": {
            "dependsOn": ["^generate:types", "copy:systems"],
            "outputs": []
        },
        "format": {
            "outputs": []
        },
        "format:check": {
            "outputs": []
        },
        "test:e2e": {
            "dependsOn": ["^build", "^generate:types"],
            "outputs": [],
            "cache": false
        }
    }
}
