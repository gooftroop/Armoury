{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "generate:theme": {
            "cache": false
        },
        "copy:systems": {
            "dependsOn": ["^build", "@armoury/theme-generator#generate:theme"],
            "outputs": ["public/systems/**"],
            "cache": false
        },
        "build": {
            "dependsOn": ["^build", "^generate:types", "copy:systems"],
            "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
            "env": ["SENTRY_DSN", "SENTRY_ORG", "SENTRY_PROJECT", "NEXT_PUBLIC_SENTRY_DSN"],
            "passThroughEnv": ["SENTRY_AUTH_TOKEN"]
        },
        "generate:types": {
            "dependsOn": ["^generate:types"],
            "outputs": ["dist/**/*.d.ts", "dist/**/*.d.ts.map"]
        },
        "test": {
            "dependsOn": ["^generate:types", "copy:systems"],
            "outputs": []
        },
        "test:integration": {
            "dependsOn": ["^generate:types"],
            "outputs": [],
            "env": ["GITHUB_TOKEN"]
        },
        "lint": {
            "outputs": []
        },
        "typecheck": {
            "dependsOn": ["^generate:types", "copy:systems"],
            "outputs": []
        },
        "format": {
            "outputs": []
        },
        "format:check": {
            "outputs": []
        },
        "test:e2e": {
            "dependsOn": ["^generate:types"],
            "outputs": [],
            "cache": false
        }
    }
}
