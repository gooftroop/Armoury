{
    "name": "armoury",
    "type": "module",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/gooftroop/Armoury.git"
    },
    "homepage": "https://github.com/gooftroop/Armoury#readme",
    "bugs": {
        "url": "https://github.com/gooftroop/Armoury/issues"
    },
    "packageManager": "npm@10.8.1",
    "engines": {
        "node": ">=24.0.0"
    },
    "workspaces": [
        "src/shared/models",
        "src/shared/data/dao",
        "src/shared/data/context",
        "src/shared/adapters/sqlite",
        "src/shared/adapters/pglite",
        "src/shared/adapters/dsql",
        "src/shared/adapters/wahapedia",
        "src/shared/adapters/github",
        "src/shared/clients/github",
        "src/shared/clients/wahapedia",
        "src/shared/clients/campaigns",
        "src/shared/clients/friends",
        "src/shared/clients/matches",
        "src/shared/clients/users",
        "src/shared/providers/bsdata",
        "src/shared/validation",
        "src/shared/config",
        "src/shared/streams",
        "src/shared/libs/network",
        "src/shared/e2e",
        "src/shared/ui",
        "src/systems/wh40k10e",
        "src/web",
        "src/mobile",
        "src/tooling/*",
        "src/services/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "test": "turbo run test",
        "lint": "turbo run lint format:check",
        "typecheck": "turbo run typecheck",
        "format": "turbo run format",
        "format:check": "turbo run format:check",
        "test:e2e": "turbo run test:e2e",
        "test:e2e:services": "turbo run test:e2e --filter='./src/services/*'",
        "test:e2e:shared": "turbo run test:e2e --filter='@armoury/data-dao'",
        "e2e:cleanup": "docker compose -f infra/localstack/docker-compose.yml down -v 2>/dev/null || true; docker compose -f docker-compose.dsql-mock.yml down -v 2>/dev/null || true; for f in src/services/*/docker-compose.yml; do dir=$(dirname \"$f\"); docker compose -f \"$f\" --project-directory \"$dir\" down -v --remove-orphans 2>/dev/null || true; done",
        "localstack:up": "docker compose -f infra/localstack/docker-compose.yml up -d --wait",
        "localstack:down": "docker compose -f infra/localstack/docker-compose.yml down -v",
        "localstack:status": "docker compose -f infra/localstack/docker-compose.yml ps",
        "localstack:bootstrap": "bash infra/localstack/bootstrap.sh",
        "e2e": "npm run localstack:up && npm run localstack:bootstrap && npm run test:e2e; EXIT=$?; npm run e2e:cleanup; exit $EXIT",
        "generate:theme": "node --import=tsx src/tooling/theme-generator/src/generate.js",
        "postinstall": "npx patch-package && node -e \"const fs=require('fs'),shim='node_modules/drizzle-kit/index.js';fs.existsSync('node_modules/drizzle-kit')&&!fs.existsSync(shim)&&fs.writeFileSync(shim,'module.exports=require(\\\"./index.mjs\\\");')\"",
        "prepare": "husky || true"
    },
    "devDependencies": {
        "@aws-sdk/client-ssm": "^3.0.0",
        "@commitlint/config-conventional": "^20.4.3",
        "@playwright/test": "^1.58.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "eslint-plugin-import-x": "^4.16.1",
        "eas-cli": "^16.0.0",
        "happy-dom": "^20.8.4",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.2",
        "patch-package": "^8.0.0",
        "tsx": "^4.21.0",
        "turbo": "^2.0.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "drizzle-kit": "^0.31.9"
    },
    "overrides": {
        "eslint-plugin-import-x": {
            "eslint": "^9.0.0 || ^10.0.0"
        },
        "typescript-eslint": "^8.56.0"
    }
}
