{
    "name": "armoury",
    "type": "module",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/gooftroop/Armoury.git"
    },
    "homepage": "https://github.com/gooftroop/Armoury#readme",
    "bugs": {
        "url": "https://github.com/gooftroop/Armoury/issues"
    },
    "packageManager": "npm@10.8.1",
    "engines": {
        "node": ">=24.0.0"
    },
    "workspaces": [
        "src/shared/models",
        "src/shared/data",
        "src/shared/adapters/sqlite",
        "src/shared/adapters/pglite",
        "src/shared/adapters/dsql",
        "src/shared/clients/github",
        "src/shared/clients/wahapedia",
        "src/shared/clients/campaigns",
        "src/shared/clients/friends",
        "src/shared/clients/matches",
        "src/shared/clients/users",
        "src/shared/providers/bsdata",
        "src/shared/validation",
        "src/shared/streams",
        "src/systems/wh40k10e",
        "src/web",
        "src/mobile",
        "src/tooling/*",
        "src/services/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "format": "turbo run format",
        "format:check": "turbo run format:check",
        "test:e2e": "turbo run test:e2e",
        "test:e2e:services": "turbo run test:e2e --filter='./src/services/*'",
        "test:e2e:shared": "turbo run test:e2e --filter='@armoury/data'",
        "generate:theme": "node --import=tsx src/tooling/theme-generator/src/generate.js",
        "postinstall": "node -e \"const fs=require('fs'),shim='node_modules/drizzle-kit/index.js';fs.existsSync('node_modules/drizzle-kit')&&!fs.existsSync(shim)&&fs.writeFileSync(shim,'module.exports=require(\\\"./index.mjs\\\");')\""
    },
    "devDependencies": {
        "@commitlint/config-conventional": "^20.4.3",
        "@playwright/test": "^1.58.2",
        "eslint-plugin-import-x": "^4.16.1",
        "lint-staged": "^16.3.2",
        "tsx": "^4.21.0",
        "turbo": "^2.0.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "drizzle-kit": "^0.31.9"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix"
        ],
        "*.{ts,tsx,js,jsx,json,md,css,html,yaml,yml}": [
            "prettier --write"
        ]
    }
}
