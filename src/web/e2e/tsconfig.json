{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true,
        "allowJs": true,
        "baseUrl": ".",
        "paths": {
            "@e2e/*": ["./*"]
        }
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules"]
}
