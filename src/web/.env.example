# Auth0 Configuration
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000

# Sentry
# Client-side DSN (exposed to browser via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SENTRY_DSN=

SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Source map upload credentials (only needed in CI/deployment)
SENTRY_AUTH_TOKEN=

# API Base URLs — LocalStack overrides
# These are auto-generated by 'npm run localstack:bootstrap' into .env.local at the repo root.
# Set manually here only if you need custom overrides.
# CAMPAIGNS_BASE_URL=http://localhost:4566/_aws/execute-api/campaigns-api/local
# USERS_BASE_URL=http://localhost:4566/_aws/execute-api/users-api/local
# MATCHES_BASE_URL=http://localhost:4566/_aws/execute-api/matches-api/local
# FRIENDS_BASE_URL=http://localhost:4566/_aws/execute-api/friends-api/local
