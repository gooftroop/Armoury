# Auth0 Configuration
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
AUTH0_AUDIENCE=
APP_BASE_URL=http://localhost:3000

# Auth0 SPA SDK (client-side SSO detection)
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=

# Sentry
# Client-side DSN (exposed to browser via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SENTRY_DSN=

SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Source map upload credentials (only needed in CI/deployment)
SENTRY_AUTH_TOKEN=

# API Base URLs — service endpoints
# For local dev: defaults are in .env.development, or run 'npm run localstack:bootstrap' to generate .env.local
# For production: set NEXT_PUBLIC_REST_BASE_URL, NEXT_PUBLIC_WS_BASE_URL, and
#   NEXT_PUBLIC_WS_PATH_PREFIX in the Vercel dashboard (scoped to Production).
# For preview: .env.production uses dotenv-expand with VERCEL_GIT_PULL_REQUEST_ID.
#
# Base URLs (override per-service URLs via .env.production expansion)
# NEXT_PUBLIC_REST_BASE_URL=https://api.armoury-app.com
# NEXT_PUBLIC_WS_BASE_URL=wss://ws.armoury-app.com
# NEXT_PUBLIC_WS_PATH_PREFIX=
#
# Per-service URLs (normally derived from base URLs in .env.production)
# NEXT_PUBLIC_USERS_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_FRIENDS_BASE_URL=http://localhost:3004
# NEXT_PUBLIC_FRIENDS_WS_URL=ws://localhost:3005
# NEXT_PUBLIC_MATCHES_BASE_URL=http://localhost:3001
# NEXT_PUBLIC_MATCHES_WS_URL=ws://localhost:3002
# NEXT_PUBLIC_CAMPAIGNS_BASE_URL=http://localhost:3000

# GitHub API Proxy
# Routes browser GitHub API requests through the Next.js server-side proxy
# to inject GITHUB_TOKEN and bypass unauthenticated rate limits (60→5000 req/hr).
# Server-side only: GITHUB_TOKEN is never exposed to the browser.
GITHUB_TOKEN=
# Client-side: tells the browser GitHubClient to use the local proxy instead of api.github.com.
# Set to /api/github for same-origin proxy (local dev and Vercel deployment).
NEXT_PUBLIC_GITHUB_PROXY_URL=/api/github
