# Test environment defaults (loaded when NODE_ENV=test).
#
# Next.js loads .env.test instead of .env.development when NODE_ENV=test.
# Playwright's webServer sets NODE_ENV=test so the dev server picks up these
# values automatically, ensuring the forged Auth0 session cookie can be
# decrypted without manual env var setup.
#
# Note: .env.local is NOT loaded in test mode (Next.js design), which
# guarantees consistent behaviour across machines.

# Auth0 — deterministic e2e values matching e2e/auth/setup.ts
AUTH0_SECRET=e2e-test-secret
AUTH0_DOMAIN=e2e.us.auth0.com
AUTH0_CLIENT_ID=e2e-fake-client-id
AUTH0_CLIENT_SECRET=e2e-fake-client-secret
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_AUTH0_DOMAIN=e2e.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=e2e-fake-client-id

# Base URLs — same as .env.development (local services)
NEXT_PUBLIC_USERS_BASE_URL=http://localhost:3000
NEXT_PUBLIC_FRIENDS_BASE_URL=http://localhost:3004
NEXT_PUBLIC_FRIENDS_WS_URL=ws://localhost:3005
NEXT_PUBLIC_MATCHES_BASE_URL=http://localhost:3001
NEXT_PUBLIC_MATCHES_WS_URL=ws://localhost:3002
NEXT_PUBLIC_CAMPAIGNS_BASE_URL=http://localhost:3000

# GitHub API proxy — routes browser requests through the server-side proxy
NEXT_PUBLIC_GITHUB_PROXY_URL=/api/github
