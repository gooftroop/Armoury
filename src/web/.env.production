# Production & Preview environment configuration.
#
# For PRODUCTION deploys: Vercel dashboard env vars (scoped to Production)
# override these values. Set NEXT_PUBLIC_REST_BASE_URL, NEXT_PUBLIC_WS_BASE_URL,
# and NEXT_PUBLIC_WS_PATH_PREFIX in the Vercel dashboard for production.
#
# For PREVIEW deploys: No dashboard overrides exist, so dotenv-expand resolves
# ${VERCEL_GIT_PULL_REQUEST_ID} from the Vercel system env vars at build time.

# Base URLs — overridden by Vercel dashboard for production
NEXT_PUBLIC_REST_BASE_URL=https://pr-${VERCEL_GIT_PULL_REQUEST_ID}.api.sandbox.armoury-app.com
NEXT_PUBLIC_WS_BASE_URL=wss://ws-sandbox.armoury-app.com
NEXT_PUBLIC_WS_PATH_PREFIX=pr-${VERCEL_GIT_PULL_REQUEST_ID}-

# Per-service URLs — expanded from base URLs above
NEXT_PUBLIC_USERS_BASE_URL=${NEXT_PUBLIC_REST_BASE_URL}/users
NEXT_PUBLIC_FRIENDS_BASE_URL=${NEXT_PUBLIC_REST_BASE_URL}/friends
NEXT_PUBLIC_FRIENDS_WS_URL=${NEXT_PUBLIC_WS_BASE_URL}/${NEXT_PUBLIC_WS_PATH_PREFIX}friends
NEXT_PUBLIC_MATCHES_BASE_URL=${NEXT_PUBLIC_REST_BASE_URL}/matches
NEXT_PUBLIC_MATCHES_WS_URL=${NEXT_PUBLIC_WS_BASE_URL}/${NEXT_PUBLIC_WS_PATH_PREFIX}matches
NEXT_PUBLIC_CAMPAIGNS_BASE_URL=${NEXT_PUBLIC_REST_BASE_URL}/campaigns

# GitHub API proxy — routes browser requests through the server-side proxy
NEXT_PUBLIC_GITHUB_PROXY_URL=/api/github
