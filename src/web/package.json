{
    "name": "@armoury/web",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "test": "vitest run",
        "lint": "eslint . && stylelint 'app/**/*.css'",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "db:generate": "TSX_TSCONFIG_PATH=tsconfig.drizzle.json NODE_OPTIONS='--import tsx' drizzle-kit generate",
        "copy:systems": "node ../tooling/scripts/copy-systems.js",
        "e2e": "npx playwright test --config e2e/playwright.config.ts",
        "e2e:ui": "npx playwright test --config e2e/playwright.config.ts --ui",
        "e2e:headed": "npx playwright test --config e2e/playwright.config.ts --headed",
        "test:integration": "vitest run --config vitest.integration.config.ts"
    },
    "dependencies": {
        "@armoury/adapters-github": "*",
        "@armoury/adapters-pglite": "*",
        "@armoury/adapters-wahapedia": "*",
        "@armoury/clients-friends": "*",
        "@armoury/clients-users": "*",
        "@armoury/data-context": "*",
        "@armoury/data-dao": "*",
        "@armoury/di": "*",
        "@armoury/models": "*",
        "@armoury/streams": "*",
        "@armoury/ui": "*",
        "@armoury/wh40k10e": "*",
        "@auth0/auth0-spa-js": "^2.11.3",
        "@auth0/nextjs-auth0": "^4.17.0",
        "@sentry/nextjs": "^10.43.0",
        "@tanstack/react-query": "^5.90.20",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "inversify": "^8.1.0",
        "lucide-react": "^0.563.0",
        "next": "^15.5.15",
        "next-intl": "^4.9.1",
        "radix-ui": "^1.4.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "rxjs": "^7.0.0",
        "tailwind-merge": "^3.4.0"
    },
    "devDependencies": {
        "@armoury/eslint": "*",
        "@armoury/prettier": "*",
        "@armoury/typescript": "*",
        "@armoury/vitest": "*",
        "@aws-sdk/client-ssm": "^3.700.0",
        "@eslint/js": "^10.0.0",
        "@next/eslint-plugin-next": "^16.1.6",
        "@tailwindcss/postcss": "^4.1.18",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "drizzle-kit": "^0.31.9",
        "eslint": "^10.0.3",
        "prettier": "^3.0.0",
        "stylelint": "^17.4.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-tailwindcss": "^1.0.1",
        "tailwindcss": "^4.2.2",
        "tsconfig-paths-webpack-plugin": "^4.2.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.56.0",
        "vitest": "^4.0.0"
    }
}
