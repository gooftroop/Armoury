# Sentry — Error Tracking & Performance Monitoring
# Leave empty for local development (Sentry silently disables)
SENTRY_DSN=

# DSQL — Aurora DSQL Database
# SSM parameter path for the cluster endpoint (resolved at runtime)
DSQL_ENDPOINT_PARAM=/armoury/dev/users/dsql-cluster-endpoint
DB_SCHEMA=public

# AWS — LocalStack Integration (optional, for local dev)
# Uncomment to route AWS SDK calls to LocalStack
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# AWS_REGION=us-east-1
