{
    "name": "@armoury/e2e",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/node/index.js"
        },
        "./*.js": {
            "types": "./dist/*.d.ts",
            "default": "./dist/node/*.js"
        }
    },
    "scripts": {
        "build": "ESBUILD_ENTRIES=src/index.ts,src/dockerSetup.ts,src/e2eEnv.ts,src/helpers.ts,src/localstackConfig.ts,src/mockBroadcaster.ts,src/dbSchema.ts node --import=tsx --input-type=module -e \"import '@armoury/esbuild/library'\"",
        "generate:types": "tsc -p tsconfig.build.json && node --input-type=module -e \"await import('@armoury/typescript/fix-declaration-paths')\"",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "@aws-sdk/dsql-signer": "*"
    },
    "devDependencies": {
        "@armoury/esbuild": "*",
        "@armoury/eslint": "*",
        "@armoury/prettier": "*",
        "@armoury/typescript": "*",
        "eslint": "^10.0.3",
        "prettier": "^3.0.0"
    }
}
