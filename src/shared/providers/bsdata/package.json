{
    "name": "@armoury/providers-bsdata",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/node/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "browser": "./dist/browser/index.js",
            "default": "./dist/node/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "browser": "./dist/browser/*.js",
            "default": "./dist/node/*.js"
        }
    },
    "scripts": {
        "build": "ESBUILD_ENTRIES=src/index.ts,src/types.ts,src/xmlParser.ts,src/constraintParser.ts,src/constraintTypes.ts node --import=tsx --input-type=module -e \"import '@armoury/esbuild/library'\"",
        "generate:types": "tsc -p tsconfig.build.json && node --input-type=module -e \"await import('@armoury/typescript/fix-declaration-paths')\"",
        "test": "vitest run",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "fast-xml-parser": "^5.3.4"
    },
    "devDependencies": {
        "@armoury/eslint": "*",
        "@armoury/prettier": "*",
        "@armoury/typescript": "*",
        "@armoury/vitest": "*",
        "@armoury/esbuild": "*",
        "eslint": "^10.0.3",
        "prettier": "^3.0.0",
        "vitest": "^4.0.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs}": "eslint --fix",
        "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,html,yaml,yml}": "prettier --write"
    }
}
