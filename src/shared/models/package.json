{
    "name": "@armoury/models",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/node/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "browser": "./dist/browser/index.js",
            "default": "./dist/node/index.js"
        }
    },
    "scripts": {
        "build": "node --import=tsx --input-type=module -e \"import '@armoury/esbuild/library'\"",
        "generate:types": "tsc -p tsconfig.build.json",
        "test": "vitest run",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "devDependencies": {
        "@armoury/eslint": "*",
        "@armoury/prettier": "*",
        "@armoury/typescript": "*",
        "@armoury/vitest": "*",
        "@armoury/esbuild": "*",
        "eslint": "^10.0.3",
        "prettier": "^3.0.0",
        "vitest": "^4.0.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs}": "eslint --fix",
        "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,html,yaml,yml}": "prettier --write"
    }
}
