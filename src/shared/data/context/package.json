{
    "name": "@armoury/data-context",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/node/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "browser": "./dist/browser/index.js",
            "default": "./dist/node/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "browser": "./dist/browser/*.js",
            "default": "./dist/node/*.js"
        }
    },
    "scripts": {
        "build": "ESBUILD_ENTRIES=src/index.ts,src/DataContext.ts,src/DataContextBuilder.ts node --import=tsx --input-type=module -e \"import '@armoury/esbuild/library'\"",
        "generate:types": "tsc -p tsconfig.build.json",
        "test": "vitest run",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "@armoury/data-dao": "*",
        "@armoury/models": "*",
        "@armoury/clients-github": "*"
    },
    "devDependencies": {
        "@armoury/eslint": "*",
        "@armoury/prettier": "*",
        "@armoury/typescript": "*",
        "@armoury/vitest": "*",
        "@armoury/esbuild": "*",
        "eslint": "^9.0.0",
        "prettier": "^3.0.0",
        "vitest": "^4.0.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs}": "eslint --fix",
        "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,html,yaml,yml}": "prettier --write"
    }
}
