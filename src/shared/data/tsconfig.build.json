{
    "extends": "@armoury/typescript/build.json",
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "dist",
        "baseUrl": ".",
        "paths": {
            "@data/*": ["./src/*"],
            "@models/*": ["../models/dist/*"],
            "@clients-github/*": ["../clients/github/dist/*"]
        }
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "src/**/__tests__/**", "src/**/__mocks__/**", "src/**/__fixtures__/**"]
}
