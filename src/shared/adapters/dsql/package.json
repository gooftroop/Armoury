{
    "name": "@armoury/adapters-dsql",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/node/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/node/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "default": "./dist/node/*.js"
        }
    },
    "scripts": {
        "build": "node --import=tsx --input-type=module -e \"import '@armoury/esbuild/library'\"",
        "generate:types": "tsc -p tsconfig.build.json",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "@aws-sdk/dsql-signer": "^3.985.0",
        "drizzle-orm": "^0.45.1",
        "pg": "^8.18.0",
        "@armoury/data-dao": "*"
    },
    "devDependencies": {
        "@armoury/eslint": "*",
        "@armoury/prettier": "*",
        "@armoury/typescript": "*",
        "@armoury/esbuild": "*",
        "@types/pg": "^8.16.0",
        "eslint": "^9.0.0",
        "prettier": "^3.0.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs}": "eslint --fix",
        "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,html,yaml,yml}": "prettier --write"
    }
}
