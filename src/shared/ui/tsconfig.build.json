{
    "extends": "@armoury/typescript/build.json",
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "dist/web",
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"],
    "exclude": [
        "node_modules",
        "dist",
        "src/**/__tests__/**",
        "src/**/__mocks__/**",
        "src/**/__fixtures__/**",
        "src/**/*.mobile.tsx",
        "src/index.mobile.ts"
    ]
}
