{
    "name": "@armoury/ui",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        },
        "./*": {
            "types": "./src/*/index.ts",
            "import": "./src/*/index.ts"
        }
    },
    "scripts": {
        "typecheck": "tsc --noEmit",
        "lint": "eslint src",
        "format": "prettier --write src",
        "format:check": "prettier --check src"
    },
    "devDependencies": {
        "@armoury/eslint": "*",
        "@armoury/typescript": "*",
        "@armoury/prettier": "*",
        "@types/react": "^19.0.0",
        "typescript": "^5"
    },
    "peerDependencies": {
        "react": ">=19.0.0",
        "react-native": ">=0.79.0",
        "@radix-ui/react-slot": "^1",
        "class-variance-authority": "^0.7",
        "clsx": "^2",
        "tailwind-merge": "^3",
        "@tamagui/core": ">=2.0.0-rc.0",
        "tamagui": ">=2.0.0-rc.0"
    },
    "peerDependenciesMeta": {
        "react-native": {
            "optional": true
        },
        "@tamagui/core": {
            "optional": true
        },
        "tamagui": {
            "optional": true
        },
        "@radix-ui/react-slot": {
            "optional": true
        },
        "class-variance-authority": {
            "optional": true
        }
    }
}
