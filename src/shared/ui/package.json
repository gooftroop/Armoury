{
    "name": "@armoury/ui",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/node/index.js",
    "types": "./dist/web/index.d.ts",
    "exports": {
        ".": {
            "react-native": {
                "types": "./dist/mobile/index.mobile.d.ts",
                "default": "./dist/mobile/index.mobile.js"
            },
            "types": "./dist/web/index.d.ts",
            "browser": "./dist/browser/index.js",
            "default": "./dist/node/index.js"
        }
    },
    "scripts": {
        "build": "node --import=tsx ./build.js",
        "generate:types": "tsc -p tsconfig.build.json && tsc -p tsconfig.mobile.json && node --input-type=module -e \"await import('@armoury/typescript/fix-declaration-paths')\" -- dist/web && node --input-type=module -e \"await import('@armoury/typescript/fix-declaration-paths')\" -- dist/mobile",
        "test": "vitest run",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.563.0",
        "radix-ui": "^1.4.3",
        "tailwind-merge": "^3.4.0"
    },
    "peerDependencies": {
        "react": "^18 || ^19",
        "react-dom": "^18 || ^19",
        "react-native": ">=0.74",
        "tamagui": "^2.0.0"
    },
    "peerDependenciesMeta": {
        "react-dom": {
            "optional": true
        },
        "react-native": {
            "optional": true
        },
        "tamagui": {
            "optional": true
        }
    },
    "devDependencies": {
        "@armoury/eslint": "*",
        "@armoury/prettier": "*",
        "@armoury/typescript": "*",
        "@armoury/vitest": "*",
        "@armoury/esbuild": "*",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "eslint": "^10.0.3",
        "prettier": "^3.0.0",
        "react-native": "~0.79.0",
        "tamagui": "2.0.0-rc.7",
        "vitest": "^4.0.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs}": "eslint --fix",
        "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,html,yaml,yml}": "prettier --write"
    }
}
