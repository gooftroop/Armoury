{
    "extends": "@armoury/typescript/base.json",
    "compilerOptions": {
        "rootDir": ".",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "rewriteRelativeImportExtensions": false,
        "jsx": "react-jsx",
        "noEmit": true,
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/__tests__/**"
    ]
}
