# Sentry — Error Tracking & Performance Monitoring
# Use EXPO_PUBLIC_ prefix for Expo runtime access
EXPO_PUBLIC_SENTRY_DSN=

# Auth0 — Authentication
# Create an Auth0 tenant at https://auth0.com and configure a Native application.
# Set the callback and logout URLs to: armoury://auth0/callback
EXPO_PUBLIC_AUTH0_DOMAIN=
EXPO_PUBLIC_AUTH0_CLIENT_ID=

# API Base URLs — service endpoints
# For local dev with LocalStack, run 'npm run localstack:bootstrap' to auto-generate .env.local
# EXPO_PUBLIC_USERS_BASE_URL=http://localhost:3000
# EXPO_PUBLIC_FRIENDS_BASE_URL=http://localhost:3004
# EXPO_PUBLIC_FRIENDS_WS_URL=ws://localhost:3005
# EXPO_PUBLIC_MATCHES_BASE_URL=http://localhost:3001
# EXPO_PUBLIC_MATCHES_WS_URL=ws://localhost:3002
# EXPO_PUBLIC_CAMPAIGNS_BASE_URL=http://localhost:3000
