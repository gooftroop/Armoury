{
    "expo": {
        "name": "Armoury",
        "slug": "armoury",
        "version": "0.0.0",
        "orientation": "portrait",
        "platforms": ["ios", "android"],
        "newArchEnabled": true,
        "scheme": "armoury",
        "ios": {
            "bundleIdentifier": "com.armoury.mobile"
        },
        "android": {
            "package": "com.armoury.mobile"
        },
        "plugins": [
            "@sentry/react-native/expo",
            "expo-router",
            ["react-native-auth0", { "domain": "${EXPO_PUBLIC_AUTH0_DOMAIN}" }]
        ]
    }
}
