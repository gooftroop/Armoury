{
    "extends": "@armoury/typescript/base.json",
    "compilerOptions": {
        "rootDir": ".",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "rewriteRelativeImportExtensions": false,
        "jsx": "react-jsx",
        "noEmit": true
    },
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": ["node_modules", "android", "ios", ".expo"]
}
