{
    "extends": "@armoury/typescript/base.json",
    "compilerOptions": {
        "rootDir": ".",
        "baseUrl": ".",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "rewriteRelativeImportExtensions": false,
        "jsx": "react-jsx",
        "noEmit": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "paths": {
            "@ui/*": ["./*"]
        }
    },
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": ["node_modules", "dist", "**/__tests__/**"]
}
